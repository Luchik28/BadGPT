import math
import random
import numpy as np

# Yay now we're on the next tutorial.
# Read Bengio et al and following their algorithm.
# Encode each word into a 30 dimensional space.
# Start off with encodings as random, and then tune with backpropogation.

words = open('names.txt', 'r').read().splitlines() # Get our words :D

#Make letter into number
chars = sorted(list(set(''.join(words))))
stoi = {s:i for i,s in enumerate(chars)}
stoi['.']=26
itos = {i:s for s,i in stoi.items()}

#takes in a LETTER and turns it into a one hot list with . as letter 27
def oneHot(c):
    out = [0 for _ in range(27)]
    curIndex = ord(c)-97
    if curIndex <0:
        curIndex=26 # Change it if it's a period
    out[curIndex] = 1
    return out

# we're starting by taking in the previous 3 letters
blockSize = 3
inputs, outputs = [],[]

for w in words[:5]:
    context = [0] * blockSize # start with 3 starting characters
    for ch in w + '.':
        ix = stoi[ch] # get the current character
        inputs.append(context) # add input to inputs, output to outputs
        outputs.append(ix)
        context = context[1:] + [ix] # update the context

# Next we need to define the embeddings
# Bengio et al crammed 17k words into 30 dimensions, so we will put 27 characters into 2 dimensions to start
# So each row represents a new letter, with 2 dimensions.
charEncodings = [[random.random() for _ in range(2)] for _ in range(27)]

# TO encode one, we multiply the one hot encoding of one thing by our charEncodings

#trial run with the letter f
# We use numPY here bc I will need to do matrix multiplication later anyway
# f = np.array(oneHot("f")) @ np.array(charEncodings)
# print(charEncodings[stoi["f"]])
# print(f)
#But rn we can just use charEncodings[stoi["f"]]

#Alright so wtf are we doing
# We define weights
W1 = [[random.random() for _ in range(100)] for _ in range(6)]
B1 = [random.random() for _ in range(100)]

# we need to do emeded inputs @ W1 + B1
# Thats the structure for a nueron
# We will need to put this into a class later to enable backprop, but that's the gist
#Time to enbed!!!!
for input in range(len(inputs)):
    for c in range(len(inputs[input])):
        inputs[input][c] = charEncodings[inputs[input][c]]

#print(len(inputs), len(inputs[0]), len(inputs[0][0]))
# So we have 32 inputs, each input has 3 2 dimension encodings of letters
# We need to multiply each of these 6 ish? inputs by each of the weights
# what he does in the vid is concatenate the 3 previous letters embeddings into 1
# He uses a fancy shmansy pytorch function, which makes me depressed

for input in range(len(inputs)):
    #inputs[input] is an array of 3 examples
    out = []
    for letter in inputs[input]:
        out.extend(letter)
    inputs[input] = out

#print(len(inputs), len(inputs[0]))

# Ok now, we can multiply them using numpy
# print(len(inputs), len(inputs[0]))
# print(len(W1), len(W1[0]))
h = np.array(inputs) @ np.array(W1) + np.array(B1)

# next we have to run our hidden layer through some squishiness
for f in range(len(h)):
    for j in range(len(h[f])):
        h[f][j] = math.tanh(h[f][j]) # What are these names :(


#Now for the final layer
# we want 27 outputs bc ts the end
W2 = [[random.random() for _ in range(27)] for _ in range(100)]
B2 = [random.random() for _ in range(27)]

logits = h @ np.array(W2) + np.array(B2)

# We exponentiate everything (e^x for x in logits), and then divide everything by it's sum (to get prob)
for x in range(len(logits)):
    for y in range(len(logits[x])):
        logits[x][y] = math.exp(logits[x][y])
    s = sum(logits[x])
    for y in range(len(logits[x])):
        logits[x][y] = logits[x][y]/s

# Next we need to get the probability of the correct letter
correctness = []

for x in range(len(logits)):
    correctness.append(logits[x][outputs[x]]) 

# Then, we make loss the negative average of each element's log.
loss = -sum([math.log(correctness[i]) for i in range(len(correctness))])/len(correctness)
print(loss)

